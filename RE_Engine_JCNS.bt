// -- SECTION 2 --
// struct ConstraintSkinSrc
typedef struct
{
    
    uint64 SourceOffset <format=hex>;
    FSkip(4);
    if (Version >= 35)
    {
        uint8 SourceCount;
        uint8 UnknownUInt8;
        uint8 UnknownUInt8;
        uint8 UnknownUInt8;
    } 
    else
    {
        uint32 SourceCount;
    }
    FSkip(-8);
    local uint returnPos = FTell();
    FSeek(SourceOffset);
    struct 
    {
        if (Version >= 35)
        { 
            uint32  SourceInfoIndex; 
            local int32 SourceHashIndex = ReadInt(header.SkinConstraintSourceTableEntry + 8 * SourceInfoIndex);
            local hash SourceHash = ReadUInt(header.HashTableEntry + 4 * SourceHashIndex);
        }
        else if (Version >= 29)
        { 
            int32  SourceHashIndex; 
            local hash SourceHash = ReadUInt(header.SkinConstraintSourceTableEntry + 4 * SourceHashIndex);
        }
        else
        {
            hash SourceHash;
        }
        float Weight; 
        
        local string readStr;
        if (Version >= 29)
        { SPrintf(readStr, "Index: %u Weight: %f", SourceHashIndex, Weight); }
        else
        { SPrintf(readStr, "Hash: %Xh Weight: %f", SourceHash, Weight); }
    } Source[SourceCount] <read=readStr, optimize=false>;
    FSeek(returnPos);
} 
ConstraintSkinSrc;

// struct ConstraintSkin
typedef struct
{
    ConstraintSkinSrc  SourceList;
    local uint64 returnPos;
    if (Version >= 35)
    {
        int32  ObjectHashIndex;
        returnPos = FTell();
        FSeek(header.HashTableEntry + ObjectHashIndex * 4);
        hash    ObjectHash;
        FSeek(returnPos);
    }
    else
    { 
        hash  ObjectHash; 
    }
    uint8 SourceCount;
    uint8 UnknownUInt8;
    uint8 UnknownUInt8;
    uint8 UnknownUInt8;
    
    local string readStr;
    if (SourceList.SourceCount > 1)
    {
        SPrintf(readStr, "%08Xh << %08Xh...<%u more>", ObjectHash, SourceList.Source[0].SourceHash, SourceList.SourceCount - 1);
    }
    else if (SourceList.SourceCount == 1)
    {
        SPrintf(readStr, "%08Xh << %08Xh", ObjectHash, SourceList.Source[0].SourceHash);
    }
} 
ConstraintSkin <read=readStr>;

// struct ConstraintSkinSrcInfo
typedef struct
{
    local uint64 returnPos;
    int32 SourceHashIndex;
    returnPos = FTell();
    FSeek(header.HashTableEntry + SourceHashIndex * 4);
    hash  SourceHash;
    FSeek(returnPos);
    uint32 UnknownUInt32;
} 
ConstraintSkinSrcInfo <read=Str("HashIndex: %u; Hash: %08Xh", SourceHashIndex, SourceHash), optimize=false>;


// -- SECTION 3 --
// struct AimTargetInfo
typedef struct
{
    uint64           Offset;
    local uint returnPos = FTell();
    FSeek(Offset);
    if (Version >= 35)
    {
        hashindexed   TargetJointHashInfo;
        if (TargetJointHashInfo.Index != 0xFFFFFFFF)
        { local hash TargetJointHash = TargetJointHashInfo.Hash; }
    }
    else
    { hash            TargetJointHash; }
    float             Influence;
    QWORD             UnknownQWORD;
    FSeek(returnPos);
} 
AimTargetInfo <read=Str("%08Xh", TargetJointHash), write="">;

// struct ConstraintAim
typedef struct
{
    AimTargetInfo     TargetInfo;
    if (Version >= 35)
    {
        hashindexed   JointHashInfo;
        hashindexed   UnknownJointHashInfo <comment="Up joint?">;
        if (JointHashInfo.Index != 0xFFFFFFFF)
        { local hash  JointHash = JointHashInfo.Hash; }
        if (UnknownJointHashInfo.Index != 0xFFFFFFFF)
        { local hash  UnknownJointHash = UnknownJointHashInfo.Hash; }
    }
    else
    { 
        hash          JointHash;
        hash          UnknownJointHash;
    }
    //float           UnknownFloat[12];
    vec3              UnknownVector;
    vec3              TrackVector;
    vec3              UnknownVector; 
    vec3              UnknownVector;
    uint8             RotationType;
    uint8             UnknownUInt8;
    uint8             UnknownUInt8;
    uint8             UnknownUInt8;
    uint8             UnknownBytes[12] <comment="Usually 0.">;
} 
ConstraintAim <read=Str("%08Xh -> %08Xh", JointHash, TargetInfo.TargetJointHash)>;


// -- SECTION  4 --
// struct MatCnsInfo
typedef struct
{
    if (Version >= 35)
    {
        int32        JointHashIndex;
        local uint64 returnPos = FTell();
        FSeek(header.HashTableEntry + JointHashIndex * 4);
        hash         JointHash;
        FSeek(returnPos);
    }
    else
    {
        hash          JointHash;
    }
    hash              MaterialNameHash;
    hash              MaterialPropertyHash;
    TransformationID  Transformation;
    uint8             UnknownUInt8;
    uint8             UnknownUInt8;
    uint8             UnknownUInt8;
} 
MatCnsInfo <read=Str("%08Xh", JointHash), write="">;



//———————————————/* - STRUCTURES - */———————————————//
// HEADER
typedef struct
{
    struct
    {
        byte   Signature[4];
        QWORD  UnknownQWORD;
        uint64 InfoEntry;
        QWORD  UnknownQWORD;
        uint64 JCNSEntry;
        QWORD  UnknownQWORD <comment="JCNS Count?">;
        FSeek(InfoEntry);
        QWORD  UnknownQWORD;
        QWORD  UnknownQWORD;
        FSeek(JCNSEntry);
        uint64 DataEntry;
        QWORD  UnknownQWORD;
    } Tags <comment="Usually the same in most files from diffent RE games.">;
    FSeek(Tags.DataEntry);
    switch (Version)
    {
    case 102: // MHWs (post-TU4)
        uint64 ConeDriverTableEntry <format=hex>;
        uint64 ConstraintInfoEntry <format=hex>;
        uint64 ObjectSettingEntry <format=hex>;
        uint64 RotExpressionInfoEntry <format=hex>;
        uint64 RotExpressionMapEntry <format=hex>;
        uint64 RotExpressionSourceHashIndicesEntry <format=hex>;
        uint64 RotExpressionHashIndicesEntry <format=hex>;
        uint64 SkinConstraintTableEntry <format=hex>;
        uint64 SkinConstraintSourceTableEntry <format=hex>;
        uint64 AimConstraintTableEntry <format=hex>;
        uint64 MaterialConstraintInfoEntry <format=hex>;
        uint64 JointExportGraphInfoEntry <format=hex>;
        uint64 SectionTableEntry <format=hex>;
        uint64 DependencyTableEntry <format=hex>;
        uint64 HashTableEntry <format=hex>;
        uint64 SkinConstraintHashTableEntry <format=hex>;
        int32  HashTableItemCount;
        uint16 ConeDriverCount;
        uint16 ConstraintCount;
        uint16 DependencyCount;
        uint16 ObjectSettingCount;
        uint16 RotExpressionInfoCount;
        uint16 RotExpressionMapCount;
        uint16 SkinConstraintCount;
        uint16 SkinConstraintHashTableItemCount;
        uint16 SkinConstraintSourceCount;
        uint16 AimConstraintCount;
        uint16 MaterialConstraintInfoCount;
        uint8 SectionCount;
        uint8  UnknownUInt8[5];
        break;
    case 35: // RE9, PRAGMATA SKETCHBOOK - DEMO, MHS3Trial
        uint64 ConeDriverTableEntry <format=hex>;
        uint64 ConstraintInfoEntry <format=hex>;
        uint64 ObjectSettingEntry <format=hex>;
        uint64 RotExpressionInfoEntry <format=hex>;
        uint64 RotExpressionMapEntry <format=hex>;
        uint64 RotExpressionSourceHashIndicesEntry <format=hex>;
        uint64 RotExpressionHashIndicesEntry <format=hex>;
        uint64 SkinConstraintTableEntry <format=hex>;
        uint64 SkinConstraintSourceTableEntry <format=hex>;
        uint64 AimConstraintTableEntry <format=hex>;
        uint64 MaterialConstraintInfoEntry <format=hex>;
        uint64 JointExportGraphInfoEntry <format=hex>;
        uint64 SectionTableEntry <format=hex>;
        uint64 DependencyTableEntry <format=hex>;
        uint64 HashTableEntry <format=hex>;
        int32  HashTableItemCount;
        uint16 ConeDriverCount;
        uint16 ConstraintCount;
        uint16 DependencyCount;
        uint16 ObjectSettingCount;
        uint16 RotExpressionInfoCount;
        uint16 RotExpressionMapCount;
        uint16 SkinConstraintCount;
        uint16 SkinConstraintSourceCount;
        uint16 AimConstraintCount;
        uint16 MaterialConstraintInfoCount;
        uint16 UnknownUInt16;
        uint8  SectionCount;
        uint8  UnknownUInt8[13];
        break;
    case 29: // MHWs (pre-TU4)
        uint64 ConeDriverTableEntry <format=hex>;
        uint64 ConstraintInfoEntry <format=hex>;
        uint64 ObjectSettingEntry <format=hex>;
        uint64 RotExpressionInfoEntry <format=hex>;
        uint64 RotExpressionMapEntry <format=hex>;
        uint64 SkinConstraintTableEntry <format=hex>;
        uint64 SkinConstraintSourceTableEntry <format=hex>;
        uint64 AimConstraintTableEntry <format=hex>;
        uint64 MaterialConstraintInfoEntry <format=hex>;
        uint64 JointExportGraphInfoEntry <format=hex>;
        uint64 SectionTableEntry <format=hex>;
        uint64 DependencyTableEntry <format=hex>;
        uint16 ConeDriverCount;
        uint16 ConstraintCount;
        uint16 DependencyCount;
        uint16 ObjectSettingCount;
        uint16 RotExpressionInfoCount;
        uint16 RotExpressionMapCount;
        uint16 SkinConstraintCount;
        uint16 SkinConstraintSourceCount;
        uint16 AimConstraintCount;
        uint16 MaterialConstraintInfoCount;
        uint8  SectionCount;
        byte UnknownBytes[11];
        break;
    case 24: // DD2
        uint64 ConeDriverTableEntry <format=hex>;
        uint64 ConstraintInfoEntry <format=hex>;
        uint64 ObjectSettingEntry <format=hex>;
        uint64 RotExpressionInfoEntry <format=hex>;
        uint64 RotExpressionMapEntry <format=hex>;
        uint64 SkinConstraintTableEntry <format=hex>;
        uint64 AimConstraintTableEntry <format=hex>;
        uint64 MaterialConstraintInfoEntry <format=hex>;
        uint64 SectionTableEntry <format=hex>;
        uint64 DependencyTableEntry <format=hex>;
        uint16 ConeDriverCount;
        uint16 ConstraintCount;
        uint16 DependencyCount;
        uint16 ObjectSettingCount;
        uint16 RotExpressionInfoCount;
        uint16 RotExpressionMapCount;
        uint16 SkinConstraintCount;
        uint16 AimConstraintCount;
        uint16 MaterialConstraintInfoCount;
        byte   UnknownBytes[14];
        break;
    case 22: // RE4R, SF6
        uint64 ConeDriverTableEntry <format=hex>;
        uint64 ConstraintInfoEntry <format=hex>;
        uint64 ObjectSettingEntry <format=hex>;
        uint64 RotExpressionInfoEntry <format=hex>;
        uint64 RotExpressionMapEntry <format=hex>;
        uint64 SkinConstraintTableEntry <format=hex>;
        uint64 AimConstraintTableEntry <format=hex>;
        uint64 MaterialConstraintInfoEntry <format=hex>;
        uint64 SectionTableEntry <format=hex>;
        uint64 DependencyTableEntry <format=hex>;
        uint16 ConeDriverCount;
        uint16 ConstraintCount;
        uint16 DependencyCount;
        uint16 ObjectSettingCount;
        uint16 RotExpressionInfoCount;
        uint16 RotExpressionMapCount;
        uint16 SkinConstraintCount;
        uint16 AimConstraintCount;
        uint16 MaterialConstraintInfoCount;
        byte   UnknownBytes[14];
        break;
    case 21: // MHRS
        uint64 ConeDriverTableEntry <format=hex>;
        uint64 ConstraintInfoEntry <format=hex>;
        uint64 ObjectSettingEntry <format=hex>;
        uint64 RotExpressionInfoEntry <format=hex>;
        uint64 RotExpressionMapEntry <format=hex>;
        uint64 SkinConstraintTableEntry <format=hex>;
        uint64 AimConstraintTableEntry <format=hex>;
        uint64 SectionTableEntry <format=hex>;
        uint64 DependencyTableEntry <format=hex>;
        uint16 ConeDriverCount;
        uint16 ConstraintCount;
        uint16 DependencyCount;
        uint16 ObjectSettingCount;
        uint16 RotExpressionInfoCount;
        uint16 RotExpressionMapCount;
        uint16 SkinConstraintCount;
        uint16 AimConstraintCount;
        byte   UnknownBytes[8];
        break;
    case 16: // RE8
        uint64 ConeDriverTableEntry <format=hex>;
        uint64 ConstraintInfoEntry <format=hex>;
        uint64 ObjectSettingEntry <format=hex>;
        uint64 RotExpressionInfoEntry <format=hex>;
        uint64 RotExpressionMapEntry <format=hex>;
        uint64 SkinConstraintTableEntry <format=hex>;
        uint64 AimConstraintTableEntry <format=hex>;
        uint64 SectionTableEntry <format=hex>;
        uint16 ConeDriverCount;
        uint16 ConstraintCount;
        uint16 ObjectSettingCount;
        uint16 RotExpressionInfoCount;
        uint16 RotExpressionMapCount;
        uint16 SkinConstraintCount;
        uint16 AimConstraintCount;
        byte   UnknownBytes[2];
        break;
    case 12: // RE3R
        uint64 ConeDriverTableEntry <format=hex>;
        uint64 ConstraintInfoEntry <format=hex>;
        uint64 ObjectSettingEntry <format=hex>;
        uint64 RotExpressionInfoEntry <format=hex>;
        uint64 RotExpressionMapEntry <format=hex>;
        uint64 SkinConstraintTableEntry <format=hex>;
        uint64 SkinConstraintSourceTableEntry <format=hex>;
        uint16 ConeDriverCount;
        uint16 ConstraintCount;
        uint16 ObjectSettingCount;
        uint16 RotExpressionInfoCount;
        uint16 RotExpressionMapCount;
        uint16 SkinConstraintCount;
        uint16 SkinConstraintSourceCount;
        byte   UnknownBytes[10];
        break;
    case 11: // RE2R, DMC5
        uint64 ConeDriverTableEntry <format=hex>;
        uint64 ConstraintInfoEntry <format=hex>;
        uint64 ObjectSettingEntry <format=hex>;
        uint64 RotExpressionInfoEntry <format=hex>;
        uint64 RotExpressionMapEntry <format=hex>;
        uint64 SkinConstraintTableEntry <format=hex>;
        uint16 ConeDriverCount;
        uint16 ConstraintCount;
        uint16 ObjectSettingCount;
        uint16 RotExpressionInfoCount;
        uint16 RotExpressionMapCount;
        uint16 SkinConstraintCount;
        byte   UnknownBytes[4];
        break;
    default:
        uint64 ConeDriverTableEntry <format=hex>;
        uint64 ConstraintInfoEntry <format=hex>;
        uint64 ObjectSettingEntry <format=hex>;
        break;
    }
} 
HEADER <name="JCNS Header">;


// BODY
typedef struct 
{
    if (header.ConeDriverCount > 0)
    {
        FSeek(header.ConeDriverTableEntry);
        ConeDriverList ConeDrivers;
    }
    if (header.ConstraintCount > 0)
    {
        FSeek(header.ConstraintInfoEntry);
        ConstraintList Constraints;
    }
    if (Version >= 21 && header.DependencyCount > 0)
    {
        FSeek(header.DependencyTableEntry);
        DependencyList Dependencies;
    }
    if (header.ObjectSettingCount > 0)
    {
        FSeek(header.ObjectSettingEntry);
        ObjectSettingList Settings;
    }
} 
BODY0 <name="JCNS Section (Type 0: Ranges)", fgcolor=0xFFBD9A, open=true>;

typedef struct 
{
    RotExpressionInfo RotExpression[header.RotExpressionInfoCount];
    FSeek(header.RotExpressionMapEntry);
    uint8 RotExpressionMap[header.RotExpressionMapCount];
    if (Version >= 35)
    {
        FSeek(header.RotExpressionSourceHashIndicesEntry);
        struct
        {
            hashindexed SourceJointHash[header.RotExpressionInfoCount];
        } RotExpressionSourceJointHashes;
        FSeek(header.RotExpressionHashIndicesEntry);
        struct
        {
            hashindexed JointHash[header.RotExpressionInfoCount];
        } RotExpressionJointHashes;
    }
}
BODY1 <name="JCNS Section (Type 1: Rotation Expression)", fgcolor=0xBDFF9A, open=true>;

typedef struct
{
    struct 
    {
        ConstraintSkin SkinConstraint[header.SkinConstraintCount] <fgcolor=0xFF7CEF, optimize=false>;
    } SkinConstraintInfo <name="SkinConstraint: Info">;
    
    if (Version >= 29 && header.SkinConstraintSourceCount != 0)
    {
        FSeek(header.SkinConstraintSourceTableEntry);
        if (Version >= 35)
        {
            struct
            {
                ConstraintSkinSrcInfo SkinConstraintSource[header.SkinConstraintSourceCount];
            } SkinConstraintSrcInfoList <name="SkinConstraint: Source Info">;
            if (Version > 35 && header.SkinConstraintHashTableItemCount > 0)
            {
                FSeek(header.SkinConstraintHashTableEntry);
                struct
                {
                    hash Hash[header.SkinConstraintHashTableItemCount];
                } SkinConstraintHashTbl <name="SkinConstraint: Hash Table">;
            }
        }
        else
        { hash SourceHashes[header.SkinConstraintSourceCount]; }
    }
}
BODY2 <name="JCNS Section (Type 2: Skin Constraints)", open=true, fgcolor=0xFF7CEF>;

typedef struct
{
    ConstraintAim AimConstraint[header.AimConstraintCount] <optimize=false>;
}
BODY3 <name="JCNS Section (Type 3: Aim)", open=true, fgcolor=0xEDDC7C>;

typedef struct
{
    FSeek(header.MaterialConstraintInfoEntry);
    MatCnsInfo MaterialConstraintInfo[header.MaterialConstraintInfoCount] <optimize=false>;
}
BODY4 <name="JCNS Section (Type 4: Material Constraints)", open=true, fgcolor=0x00EDFF>;

typedef struct 
{
    uint64 PathOffset <format=hex>;
    local uint64 returnPos = FTell();
    FSeek(PathOffset);
    wstring Path;
    FSeek(returnPos);
} 
BODY5 <name="JCNS Section (Type 5: Joint Export Graph)", open=true, fgcolor=0x0000ED>;

typedef struct(uint8 SectionCount)
{
    local uint8 SectionCount = SectionCount;
    local uint8 _ = 0;
    for (_; _ < SectionCount; ++_)
    {
        //uint32 SectionType;
        enum<uint32> {
            Ranges,
            RotationExpressions,
            SkinConstraints,
            Aim,
            MaterialConstraints,
            JointExportGraph
        } SectionType;
    }
}
SECTIONTBL <name="JCNS Sections", read=Str("%u JCNS Section(s)", SectionCount), bgcolor=cBlack, fgcolor=cWhite>;

typedef struct 
{
    hash Hash[header.HashTableItemCount];
} 
HASHTBL <name="JCNS Hash Table", open=true, fgcolor=0x45C032>;



//—————————————————/* - FILES - */—————————————————//
uint32 Version;
HEADER header;

switch (Version)
{
    case 102: // MHWs (TU4)
        if (header.ConeDriverCount > 0 || header.ConstraintCount > 0)
        {
            FSeek(header.ConeDriverTableEntry);
            BODY0 body0;
        }
        if (header.RotExpressionInfoCount > 0)
        {
            FSeek(header.RotExpressionInfoEntry);
            BODY1 body1;
        }
        if (header.SkinConstraintCount > 0)
        {
            FSeek(header.SkinConstraintTableEntry);
            BODY2 body2;
        }
        if (header.AimConstraintCount > 0)
        {
            FSeek(header.AimConstraintTableEntry);
            BODY3 body3;
        }
        if (header.MaterialConstraintInfoCount > 0)
        {
            FSeek(header.MaterialConstraintInfoEntry);
            BODY4 body4;
        }
        if (header.JointExportGraphInfoEntry > 0)
        {
            FSeek(header.JointExportGraphInfoEntry);
            BODY5 body5;
        }
        if (header.SectionCount > 0)
        {
            FSeek(header.SectionTableEntry);
            SECTIONTBL sectiontbl(header.SectionCount);
        }
        if (header.HashTableItemCount > 0)
        {
            FSeek(header.HashTableEntry);
            HASHTBL HashTable;
        }
        break;
    case 35: // RE9, PRAGMATA SKETCHBOOK - DEMO, MHS3Trial
        if (header.ConeDriverCount > 0 || header.ConstraintCount > 0)
        {
            FSeek(header.ConeDriverTableEntry);
            BODY0 body0;
        }
        if (header.RotExpressionInfoCount > 0)
        {
            FSeek(header.RotExpressionInfoEntry);
            BODY1 body1;
        }
        if (header.SkinConstraintCount > 0)
        {
            FSeek(header.SkinConstraintTableEntry);
            BODY2 body2;
        }
        if (header.AimConstraintCount > 0)
        {
            FSeek(header.AimConstraintTableEntry);
            BODY3 body3;
        }
        if (header.MaterialConstraintInfoCount > 0)
        {
            FSeek(header.MaterialConstraintInfoEntry);
            BODY4 body4;
        }
        if (header.JointExportGraphInfoEntry > 0)
        {
            FSeek(header.JointExportGraphInfoEntry);
            BODY5 body5;
        }
        if (header.SectionCount > 0)
        {
            FSeek(header.SectionTableEntry);
            SECTIONTBL sectiontbl(header.SectionCount);
        }
        if (header.HashTableItemCount > 0)
        {
            FSeek(header.HashTableEntry);
            HASHTBL HashTable;
        }
        break;
    case 29: // MHWs
        if (header.ConeDriverCount > 0 || header.ConstraintCount > 0)
        {
            BODY0 body0;
        }
        if (header.RotExpressionInfoCount > 0)
        {
            FSeek(header.RotExpressionInfoEntry);
            BODY1 body1;
        }
        if (header.SkinConstraintCount > 0)
        {
            FSeek(header.SkinConstraintTableEntry);
            BODY2 body2;
        }
        if (header.AimConstraintCount > 0)
        {
            FSeek(header.AimConstraintTableEntry);
            BODY3 body3;
        }
        if (header.MaterialConstraintInfoCount > 0)
        {
            FSeek(header.MaterialConstraintInfoEntry);
            BODY4 body4;
        }
        if (header.JointExportGraphInfoEntry > 0)
        {
            FSeek(header.JointExportGraphInfoEntry);
            BODY5 body5;
        }
        if (header.SectionCount > 0)
        {
            FSeek(header.SectionTableEntry);
            SECTIONTBL sectiontbl(header.SectionCount);
        }
        break;
    case 24: // DD2
        if (header.ConeDriverCount > 0 || header.ConstraintCount > 0)
        {
            BODY0 body0;
        }
        if (header.RotExpressionInfoCount > 0)
        {
            FSeek(header.RotExpressionInfoEntry);
            BODY1 body1;
        }
        if (header.SkinConstraintCount > 0)
        {
            FSeek(header.SkinConstraintTableEntry);
            BODY2 body2;
        }
        if (header.AimConstraintCount > 0)
        {
            FSeek(header.AimConstraintTableEntry);
            BODY3 body3;
        }
        if (header.MaterialConstraintInfoCount > 0)
        {
            FSeek(header.MaterialConstraintInfoEntry);
            BODY4 body4;
        }
        FSeek(header.SectionTableEntry);
        SECTIONTBL sectiontbl(5);
        break;
    case 22: // RE4R
        if (header.ConeDriverCount > 0 || header.ConstraintCount > 0)
        {
            BODY0 body0;
        }
        if (header.RotExpressionInfoCount > 0)
        {
            FSeek(header.RotExpressionInfoEntry);
            BODY1 body1;
        }
        if (header.SkinConstraintCount > 0)
        {
            FSeek(header.SkinConstraintTableEntry);
            BODY2 body2;
        }
        if (header.AimConstraintCount > 0)
        {
            FSeek(header.AimConstraintTableEntry);
            BODY3 body3;
        }
        if (header.MaterialConstraintInfoCount > 0)
        {
            FSeek(header.MaterialConstraintInfoEntry);
            BODY4 body4;
        }
        FSeek(header.SectionTableEntry);
        SECTIONTBL sectiontbl(5);
        break;
    case 21: // MHRS
        if (header.ConeDriverCount > 0 || header.ConstraintCount > 0)
        {
            BODY0 body0;
        }
        if (header.RotExpressionInfoCount > 0)
        {
            FSeek(header.RotExpressionInfoEntry);
            BODY1 body1;
        }
        if (header.SkinConstraintCount > 0)
        {
            FSeek(header.SkinConstraintTableEntry);
            BODY2 body2;
        }
        if (header.AimConstraintCount > 0)
        {
            FSeek(header.AimConstraintTableEntry);
            BODY3 body3;
        }
        FSeek(header.SectionTableEntry);
        SECTIONTBL sectiontbl(4);
        break;
    case 16: // RE8
        if (header.ConeDriverCount > 0 || header.ConstraintCount > 0)
        {
            BODY0 body0;
        }
        if (header.RotExpressionInfoCount > 0)
        {
            FSeek(header.RotExpressionInfoEntry);
            BODY1 body1;
        }
        if (header.SkinConstraintCount > 0)
        {
            FSeek(header.SkinConstraintTableEntry);
            BODY2 body2;
        }
        if (header.AimConstraintCount > 0)
        {
            FSeek(header.AimConstraintTableEntry);
            BODY3 body3;
        }
        FSeek(header.SectionTableEntry);
        SECTIONTBL sectiontbl(4);
        break;
    case 12: // RE3R
        if (header.ConeDriverCount > 0 || header.ConstraintCount > 0)
        {
            BODY0 body0;
        }
        if (header.RotExpressionInfoCount > 0)
        {
            FSeek(header.RotExpressionInfoEntry);
            BODY1 body1;
        }
        if (header.SkinConstraintCount > 0)
        {
            FSeek(header.SkinConstraintTableEntry);
            BODY2 body2;
        }
        break;
    case 11: // RE2R, DMC5
        if (header.ConeDriverCount > 0 || header.ConstraintCount > 0)
        {
            BODY0 body0;
        }
        if (header.RotExpressionInfoCount > 0)
        {
            FSeek(header.RotExpressionInfoEntry);
            BODY1 body1;
        }
        if (header.SkinConstraintCount > 0)
        {
            FSeek(header.SkinConstraintTableEntry);
            BODY2 body2;
        }
        break;
}