// struct ConeDriver_v2
typedef struct
{
    WStringOffset  Name;
    vec4           Direction;
    matrix4x3      Matrix;
    hash           NameHash;
    hashindexed    JointHash;
    hashindexed    ParentJointHash;
    hashindexed    SymmetryJointHash;
    float          AngleRad <comment="Angle in radians.">;
    uint32         UnknownUInt32;
    uint8          UnknownUInt8;
    uint8          UnknownUInt8;
    uint8          UnknownUInt8;
    uint8          UnknownUInt8;
    uint8          UnknownUInt8;
    uint8          UnknownUInt8;
    uint8          UnknownUInt8;
    uint8          UnknownUInt8;
}
ConeDriver_v2 <read=Str("%s : [%08Xh] -- %08Xh", Name.WString, JointHash.Hash, ParentJointHash.Hash), optimize=false>;

// struct ConeDriver_v1
typedef struct
{
    WStringOffset      Name;
    WStringOffset      Joint;
    WStringOffset      ParentJoint;
    if (Version >= 24)
    {
        WStringOffset  SymmetryJoint;
    }
    vec4               Direction;
    if (Version >= 24)
    {
        matrix4x3      Matrix;
    }
    else if (Version > 12)
    {
        vec4           Translation;
    }
    hash               NameHash;
    hash               JointHash;
    hash               ParentJointHash;
    if (Version >= 24)
    { 
        hash           SymmetryJointHash;
    }
    float              AngleRad <comment="Angle in radians.">;
    if (Version >= 24)
    { 
        uint32         UnknownUInt32;
    }
    uint8              UnknownUInt8;
    uint8              UnknownUInt8;
    uint8              UnknownUInt8;
    uint8              UnknownUInt8;
    uint8              UnknownUInt8;
    uint8              UnknownUInt8;
    uint8              UnknownUInt8;
    uint8              UnknownUInt8;
} 
ConeDriver_v1 <read=Str("%s : %s[%08Xh] -- %s", Name.WString, Joint.WString, JointHash, ParentJoint.WString), optimize=false>;

// struct ConeDriverList
typedef struct
{
    if (Version >= 35)
    { ConeDriver_v2 ConeDriver[header.ConeDriverCount]; }
    else
    { ConeDriver_v1 ConeDriver[header.ConeDriverCount]; }
} 
ConeDriverList <read=Str("  < %u Cone Driver(s)... >  ", header.ConeDriverCount), fgcolor=0xDCED7C>;

//struct ConeDriverInfoList
typedef struct 
{
    uint64  Offset <format=hex>;
    local uint64 ReturnPos = FTell();
    if (Version >= 35) { FSkip(36); }
    else if (Version > 12) { FSkip(32); }
    else { FSkip(24); }
    uint8   Count;
    if (Count > 0)
        {
        FSeek(Offset);
        struct 
        {
            float    UnknownFloat32;
            if (Version >= 24)
            {
                float    UnknownFloat32;
                float    UnknownFloat32;
                float    UnknownFloat32;
            }
            float        AngleDeg;
            uint8        UnknownUInt8;
            uint16       ConeDriverIndex;
            uint8        UnknownUInt8;
        }
        ConeDriverInfo[Count] <read=Str("(%u) %s : %f", ConeDriverIndex, parentof(parentof(parentof(parentof(this)))).ConeDrivers.ConeDriver[ConeDriverIndex].Name.WString, AngleDeg), optimize=false>;
    }
    FSeek(ReturnPos);
}
ConeDriverInfoList <name="Constraint: Cone Driver List", read=Str("< %u Constraint Cone Driver(s) >", Count), fgcolor=cLtYellow>;

// struct SourceExtraInfo
typedef struct
{
    
    float  FromX <name="X: From Range">;
    float  ToX <name="X: To Range">;
    float  FromY <name="Y: From Range">;
    float  ToY <name="Y: To Range">;
    float  FromZ <name="Z: From Range">;
    float  ToZ <name="Z: To Range">;
    uint32 UnknownUInt32;
} 
ComplexSrcMapping;

// struct ConstraintSource_v2
typedef struct
{
    local uint64 returnPos;
    uint64           ComplexMappingInfoOffset <fgcolor=cLtGreen>; 
    WStringOffset    SourceName <name="Source: Name">;
    if (Version >= 35)
    { 
        hashindexed  SourceHashFromHashTbl <name="Source: Hash", comment="Hash here is read from file directly.">;
        if (SourceHashFromHashTbl.Index != 0xFFFFFFFF)
        { local hash SourceHash <hidden=true> = SourceHashFromHashTbl.Hash; }
    }
    else
    { hash           SourceHash <name="Source: Hash", comment="Hash here is read from file directly.">; }
    uint16           ComplexMappingInfoCount <fgcolor=cLtGreen>;
    uint16           UnknownUInt16 <fgcolor=cLtBlue>;
    uint8            UnknownUInt8;
    InterpolationID  Interpolation <name="UnknownUInt8 (Interpolation?)", comment="Not sure.">;
    AxisID           SourceAxis <name="Source: Axis">;
    byte             UnknownUInt8;
    byte             UnknownUInt8;
    byte             UnknownUInt8;
    byte             UnknownUInt8;
    byte             UnknownUInt8;
    range3           MapFromRange <name="MapFrom: Range">;
    range3           MapToRange <name="MapTo: Range">;
    vec4             UnknownVector4D;
    
    returnPos = FTell();
    FSeek(ComplexMappingInfoOffset);
    while (true)
    {
        if (FTell() % 16 != 0) FSkip(1);
        else break;
    }
    if (ComplexMappingInfoCount > 0) // Prevent warnings
    { ComplexSrcMapping ComplexMappingInfo[ComplexMappingInfoCount] <fgcolor=cLtGreen, optimize=false>; }
    FSeek(returnPos);
    
    local string readStr;
    local hash readHash = murmurhash3_32(SourceName.WString);
    SPrintf(readStr, "%s - Hash: %08Xh; Hash(Generated): %08Xh", SourceName.WString, SourceHash, readHash);
} 
ConstraintSource_v2 <read=readStr, write="">;

// struct ConstraintSource_v1
typedef struct
{
    WStringOffset    SourceName <name="Source: Name">;
    hash             SourceHash <name="Source: Hash", comment="Hash here is read from file directly.">;
    range3           MapFromRange <name="MapFrom: Range">;
    range3           MapToRange <name="MapTo: Range">;
    byte             UnknownUInt8;
    byte             UnknownUInt8;
    AxisID           SourceAxis;
    byte             UnknownBytes[5];
    vec4             UnknownVector4D;
    DWORD            UnknownDWORD;
   
    local string readStr;
    local hash readHash = murmurhash3_32(SourceName.WString);
    SPrintf(readStr, "%s - Hash: %08Xh; Hash(Generated): %08Xh", SourceName.WString, SourceHash, readHash);
} 
ConstraintSource_v1 <read=readStr, write="">;

// struct ConstraintSourceList
typedef struct
{
    //byte CnsInput <name="Input name here to add source...", read="  <Object Name>  ", write=AddCSource(WStr(value))>;
    //FSkip(-1);
    uint64  OffsetSourceList;
    local uint64 ReturnPos = FTell();
    if (Version > 12) 
    { 
        FSkip(25);
        if (Version >= 35) { FSkip(4); } 
        uint8   SourceCount;
        FSeek(OffsetSourceList);
        if (SourceCount > 0) // Prevent warnings
        { ConstraintSource_v2 CSource[SourceCount] <name="Constraint: Source", optimize=false>; }
    }
    else 
    { 
        FSkip(17); 
        uint8   SourceCount;
        FSeek(OffsetSourceList);
        if (SourceCount > 0) // Prevent warnings
        { ConstraintSource_v1 CSource[SourceCount] <name="Constraint: Source", optimize=false>; }
    }
    FSeek(ReturnPos);
} 
ConstraintSourceList <name="Constraint: Source List", read=Str("< %u Constraint Source(s) >", parentof(this).SourceCount), fgcolor=cLtRed>;

// struct Constraint
typedef struct
{
    local uint64 returnPos;
    ConeDriverInfoList     ConeDriverCns;
    ConstraintSourceList   CSourceList <open=suppress>;
    WStringOffset          ObjectName <name="Object: Name", comment="Name of joint, material, blendshape, RSZobject, etc.">;
    if (Version > 12)
    { WStringOffset        Property <name="Object: Property", comment="Object Property, such as Blend_[A-F] for material, etc.">; }
    if (Version >= 35)
    { 
        hashindexed        ObjectHashFromHashTbl <name="Object: Hash (From Hash Table)", comment="Hash here is read from file directly.">;
    }
    hash                   ObjectHash <name="Object: Hash", comment="Hash here is read from file directly.">;
    if (Version > 12)
    { hash                 PropertyHash <name="Property: Hash", comment="Hash here is read from file directly.">; }
    else
    { uint32               UnknownUInt32; }
    if (Version >= 35)
    {
        uint8              ConeDriverInfoCount <fgcolor=cLtYellow, bgcolor=cBlack>;
        uint8              SourceCount   <fgcolor=cLtRed, bgcolor=cBlack>;
        flags_cns          Flags <bgcolor=cBlack>; 
        TransformationID   Transformation <bgcolor=cBlack>;
        vec4               UnknownVector4D;
        float              UnknownFloat32[2];
        uint8              UnknownUInt8;
        AxisID             TransformAxis;
        uint8              UnknownUInt8;
        uint8              UnknownUInt8;
        uint8              UnknownUInt8;
        uint8              UnknownUInt8;
        uint8              UnknownUInt8;
        uint8              UnknownUInt8;
    }
    else
    {
        uint8              ExtraConstraintInfoCount <fgcolor=cLtYellow, bgcolor=cBlack>;
        uint8              SourceCount   <fgcolor=cLtRed, bgcolor=cBlack>;
        uint8              UnknownUInt8   <bgcolor=cBlack>;
        TransformationID   Transformation <bgcolor=cBlack>;
        uint8              UnknownUInt8   <bgcolor=cBlack>;
        AxisID             TransformAxis  <bgcolor=cBlack>;
        uint8              UnknownUInt8   <bgcolor=cBlack>;
        uint8              UnknownUInt8   <bgcolor=cBlack>;
        vec4               UnknownVector4D;
    }
    if (Version >= 21 && Version < 35)
    {
        float              UnknownFloat32[2];
        uint8              UnknownUInt8;
        uint8              UnknownUInt8;
        uint8              UnknownUInt8;
        uint8              UnknownUInt8;
        uint8              UnknownUInt8;
        uint8              UnknownUInt8;
        uint8              UnknownUInt8;
        uint8              UnknownUInt8;
    }
    local string readStr;
    local hash readHash = murmurhash3_32(ObjectName.WString);
    
    if (SourceCount > 1) { SPrintf(readStr, "%s[%08Xh|%08Xh] << %s[%08Xh|%08Xh]...<%u more>", ObjectName.WString, ObjectHash, readHash, CSourceList.CSource[0].SourceName.WString, CSourceList.CSource.SourceHash, CSourceList.CSource[0].readHash, SourceCount - 1); }
    else if (SourceCount == 1) { SPrintf(readStr, "%s[%08Xh|%08Xh] << %s[%08Xh|%08Xh]", ObjectName.WString, ObjectHash, readHash, CSourceList.CSource.SourceName.WString, CSourceList.CSource.SourceHash, CSourceList.CSource.readHash); }
    else { SPrintf(readStr, "%s[%08Xh|%08Xh]", ObjectName.WString, ObjectHash, readHash); }
} 
ConstraintInfo <read=readStr, write="">;

// struct ConstraintList
typedef struct 
{
    //byte CnsInput <name="Input joints here to add a new constraint...", read="Example: ObjectName;SourceName1;SourceName2;...", write=AddConstraint(Str(value))>;
    //FSkip(-1);
    ConstraintInfo Constraint[header.ConstraintCount] <name="Constraint", optimize=false>;
} 
ConstraintList <read=Str("  < %u Constraint(s)... >  ",header.ConstraintCount)>;

// struct Dependency
typedef struct
{
    uint64 Offset;
    uint64 SourceCount;
    if (Offset != 0)
    {
        local uint ReturnPos = FTell();
        FSeek(Offset);
        hash ObjectHash;
        
        local string readStr;
        if (SourceCount != 0)
        {
            for (_ = 0; _ < SourceCount; ++_)  // Don't collapse it
            {
                hash SourceHash;
            }
            if (SourceCount == 1) { SPrintf(readStr, "%08Xh << %08Xh", ObjectHash, SourceHash); }
            else { SPrintf(readStr, "%08Xh << %08Xh...<%u more>", ObjectHash, SourceHash[0], SourceCount - 1); }
        }
        else { SPrintf(readStr, "%08Xh", ObjectHash); }
        
        FSeek(ReturnPos);
    }
} 
DependencyInfo <read=readStr>;

// struct DependencyList
typedef struct
{
    //byte RefInput <name="Input here to add a new dependence...", read="ObjectHash - SourceHash">;
    //FSkip(-1);
    DependencyInfo Dependency[header.DependencyCount] <optimize=false>;
} 
DependencyList <read=Str("  < %u Dependencie(s)... >  ", header.DependencyCount)>;

